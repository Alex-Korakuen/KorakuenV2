# ============================================================
# Korakuen V2 — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# --- Supabase ---
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: direct Postgres connection string for psql / migrations / scripts.
# Find this in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Not required by the running app — runtime DB access goes through the Supabase clients above.
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# --- Cron jobs (Vercel Cron) ---
# Shared secret used to authenticate the Vercel Cron requests at /api/cron/*.
# Generate with: openssl rand -base64 32
# Set the SAME value in Vercel → Project → Settings → Environment Variables.
CRON_SECRET=replace-me-with-a-random-string

# --- SUNAT / Contact Lookup ---
# Register at https://apis.net.pe (decolecta) to get a token
# Used for RUC/DNI lookup when creating contacts
DECOLECTA_TOKEN=your-decolecta-api-token

# --- Google Drive (Phase 1: not needed yet, Phase 3: AI agent) ---
# GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY=path/to/service-account.json
