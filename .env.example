# ============================================================
# Korakuen V2 — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# --- Supabase ---
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Find this in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Used by the exchange rate cron job (Python) for direct Postgres access
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- SUNAT / Contact Lookup ---
# Register at https://apis.net.pe (decolecta) to get a token
# Used for RUC/DNI lookup when creating contacts
DECOLECTA_TOKEN=your-decolecta-api-token

# --- Google Drive (Phase 1: not needed yet, Phase 3: AI agent) ---
# GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY=path/to/service-account.json
